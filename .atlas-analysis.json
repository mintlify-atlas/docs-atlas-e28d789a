        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "configuration"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/resolvers",
              "guides/typescript",
              "guides/shared-configs",
              "guides/settings"
            ]
          }
        ]
      },
      {
        "tab": "Rules",
        "groups": [
          {
            "group": "Static Analysis",
            "pages": [
              "rules/no-unresolved",
              "rules/named",
              "rules/default",
              "rules/namespace",
              "rules/no-cycle",
              "rules/no-restricted-paths",
              "rules/no-internal-modules"
            ]
          },
          {
            "group": "Helpful Warnings",
            "pages": [
              "rules/export",
              "rules/no-deprecated",
              "rules/no-extraneous-dependencies",
              "rules/no-unused-modules",
              "rules/no-mutable-exports"
