{
  "projectType": "sdk-library",
  "projectName": "eslint-plugin-import",
  "projectDescription": "An ESLint plugin that lints ES2015+ import/export syntax to prevent misspellings, missing files, and incorrect imports.",
  "theme": "luma",
  "primaryColor": "#848c8e",
  "lightColor": "#11161e",
  "darkColor": "#cfd0d2",
  "navigation": {
    "tabs": [
