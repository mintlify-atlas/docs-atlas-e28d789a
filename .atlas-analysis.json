          },
          {
            "group": "Style Guide",
            "pages": [
              "rules/order",
              "rules/no-duplicates",
              "rules/first",
              "rules/extensions",
              "rules/newline-after-import",
              "rules/no-namespace"
            ]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "46 lint rules for ES2015+ import/export syntax",
    "Static analysis to detect unresolved imports and missing exports",
    "Configurable module resolvers (Node, webpack, TypeScript)",
    "Shared configs: recommended, errors, warnings, typescript, react",
    "Support for both legacy (.eslintrc) and flat (eslint.config.js) ESLint config formats",
    "Import ordering and style enforcement",
    "Circular dependency detection",
    "TypeScript-aware linting with custom parsers"
  ],
  "publicApiSurface": [
